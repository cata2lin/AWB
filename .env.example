# ===========================
# AWB Print Manager — .env
# ===========================

# Frisbo API Configuration
FRISBO_API_TOKEN=your_bearer_token_here
FRISBO_ORG_TOKENS=[{"name":"store1","token":"token1"},{"name":"store2","token":"token2"}]

# Database — PostgreSQL
DATABASE_URL=postgresql://awb_user:CHANGE_THIS_PASSWORD@localhost:5432/awbprint

# PDF Storage path
PDF_STORAGE_PATH=./storage

# CORS — comma-separated origins (optional, defaults include awb.arona.ro)
# ALLOWED_ORIGINS=https://awb.arona.ro,http://localhost:5143

# Google Sheets — CPA marketing data (optional)
# GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account",...}
# GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
